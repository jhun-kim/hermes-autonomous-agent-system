#!/usr/bin/env bash
set -euo pipefail

# Reusable Hermes Discord/Gateway wrapper for the installed gateway adapter.
# Configure HERMES_GATEWAY_ROUTER_CONFIG when this script is copied outside
# the repository, or keep the default examples/hermes-router.json path while
# trying it locally from a source checkout.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG="${HERMES_GATEWAY_ROUTER_CONFIG:-$SCRIPT_DIR/../examples/hermes-router.json}"
MODE="${1:---dry-run}"
if [[ "$MODE" == "--dry-run" ]]; then
  shift || true
  exec hermes-gateway-adapter --config "$CONFIG" --dry-run "$@"
elif [[ "$MODE" == "--live" ]]; then
  shift || true
  # Live mode intentionally does not pass --allow-any-repo. Non-dry-run calls
  # therefore fail closed unless the config's allow_repos list or explicit
  # --allow-repo arguments permit the selected repository.
  exec hermes-gateway-adapter --config "$CONFIG" "$@"
else
  # Safe default: unknown first arguments are treated as adapter arguments, but
  # the wrapper still forces dry-run routing.
  exec hermes-gateway-adapter --config "$CONFIG" --dry-run "$@"
fi
