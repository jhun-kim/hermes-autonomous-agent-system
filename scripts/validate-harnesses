#!/usr/bin/env python3
"""Validate Markdown harness engineering artifacts.

This script intentionally checks Markdown files rather than owning the workflow in
Python. The operating logic remains user-editable in `.md` files.
"""
from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]

REQUIRED_FILES = [
    "harnesses/issue-loop.md",
    "policies/issue-first.md",
    "policies/cmux-first.md",
    "policies/evidence-and-no-fabrication.md",
    "templates/worker-prompt.md",
    "templates/follow-up-issue.md",
    "templates/verification-report.md",
    "examples/basic-issue-loop.md",
]

REQUIRED_SECTIONS = {
    "harnesses/issue-loop.md": [
        "## Purpose",
        "## Inputs",
        "## Required Workspace",
        "## Steps",
        "## Verification",
        "## Prohibited",
    ],
    "policies/issue-first.md": ["## Rule", "## Required Order", "## Exceptions"],
    "policies/cmux-first.md": ["## Rule", "## Discord Thread Mapping", "## Visible Execution"],
    "policies/evidence-and-no-fabrication.md": ["## Rule", "## Required Evidence", "## Prohibited"],
}

REQUIRED_TERMS = {
    "harnesses/issue-loop.md": ["GitHub issue", "cmux", "Codex", "follow-up issue"],
    "policies/issue-first.md": ["GitHub issue", "source of truth"],
    "policies/cmux-first.md": ["Discord thread", "cmux workspace", "visible"],
}


def main() -> int:
    failures: list[str] = []

    for relative in REQUIRED_FILES:
        path = ROOT / relative
        if not path.exists():
            failures.append(f"missing required file: {relative}")
            continue
        text = path.read_text(encoding="utf-8")
        if not text.startswith("# "):
            failures.append(f"{relative}: first line must be a Markdown H1")
        for section in REQUIRED_SECTIONS.get(relative, []):
            if section not in text:
                failures.append(f"{relative}: missing section {section}")
        for term in REQUIRED_TERMS.get(relative, []):
            if term not in text:
                failures.append(f"{relative}: missing required term {term!r}")

    if failures:
        print("Markdown harness validation failed:")
        for failure in failures:
            print(f"- {failure}")
        return 1

    print(f"Markdown harness validation passed: {len(REQUIRED_FILES)} files checked")
    return 0


if __name__ == "__main__":
    sys.exit(main())
